# Business Receptionist Agent Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
TIMEZONE=Asia/Kuala_Lumpur

# API Key for protecting endpoints (leave empty to disable auth)
API_KEY=

# CORS origin (use * for development, specific domain for production)
CORS_ORIGIN=*

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
GOOGLE_TOKEN_FILE=./token.json

# Business Email (used as default attendee in WhatsApp bookings)
BUSINESS_EMAIL=your_business_email@example.com

# Ollama AI Configuration
OLLAMA_HOST=http://localhost:11434
